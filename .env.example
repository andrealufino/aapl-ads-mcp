# Apple Search Ads API credentials
# Copy this file to .env and fill in your real values.
# NEVER commit .env or *.pem files to version control — both are in .gitignore.

# ─── ASA API credentials ──────────────────────────────────────────────────────
# All four values come from ASA → Account Settings → User Management → API tab.
# Create a user, assign the API Account Manager role, then upload your public key
# to get client_id, team_id, and key_id. Find org_id in Account Settings.

# The client identifier issued by Apple — always starts with "SEARCHADS."
ASA_CLIENT_ID=SEARCHADS.FAKE-CLIENT-ID-DO-NOT-USE

# Same as client_id for the v5 API (Apple uses them interchangeably)
ASA_TEAM_ID=SEARCHADS.FAKE-TEAM-ID-DO-NOT-USE

# The key identifier shown after uploading your public key in the ASA UI
ASA_KEY_ID=FAKE-KEY-ID-00000000-0000-0000-0000-000000000000

# Your organization ID — found in ASA → Account Settings (numeric, 7–9 digits)
ASA_ORG_ID=0000000

# ─── Private key ──────────────────────────────────────────────────────────────
# Provide your PKCS#8 PEM private key in ONE of two ways. If both are set,
# ASA_PRIVATE_KEY (inline) takes precedence over ASA_PRIVATE_KEY_PATH (file).
#
# OPTION A — File path (recommended for local dev)
#
# Absolute path to your PKCS#8 PEM private key file.
#
# IMPORTANT: Use an ABSOLUTE path — tilde (~) is NOT expanded by Node.js.
#   ✗  ~/keys/private-key.pem     (will fail at startup)
#   ✓  /Users/you/keys/private-key.pem
#
# The file must start with "-----BEGIN PRIVATE KEY-----" (PKCS#8 format).
# If your file starts with "-----BEGIN EC PRIVATE KEY-----" (SEC1 format),
# convert it first:
#   openssl pkcs8 -topk8 -nocrypt -in ec-key.pem -out private-key.pem
ASA_PRIVATE_KEY_PATH=/absolute/path/to/private-key.pem

# OPTION B — Inline PEM (recommended for containers, cloud, CI)
#
# The full PKCS#8 PEM contents as a single string. Newlines must be preserved
# (use \n in shells that support escapes, or rely on multi-line env loaders).
# Useful when mounting a file is impractical (Docker, Glama, Render, Fly, etc.).
#
# Example (do NOT use this fake value):
#   ASA_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIGHAgEA...\n-----END PRIVATE KEY-----\n"
# ASA_PRIVATE_KEY=
