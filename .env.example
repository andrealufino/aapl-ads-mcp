# Apple Search Ads API credentials
# Copy this file to .env and fill in your real values
# NEVER commit .env or any .pem files to version control

# From ASA > Account Settings > User Management > API
ASA_CLIENT_ID=SEARCHADS.FAKE-CLIENT-ID-EXAMPLE
ASA_TEAM_ID=SEARCHADS.FAKE-TEAM-ID-EXAMPLE
ASA_KEY_ID=FAKE-KEY-ID-EXAMPLE-00000000-0000-0000-0000-000000000000
ASA_ORG_ID=0000000

# Path to your ES256 private key file (keep outside repo root if possible)
ASA_PRIVATE_KEY_PATH=./private-key.pem
